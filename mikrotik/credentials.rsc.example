# ============================================================================
# Credentials sablon a Dell T320 Fan Control telepítéshez
#
# HASZNÁLAT:
#   1. Másold ezt a fájlt credentials.rsc néven
#   2. Töltsd ki az alábbi értékeket a saját környezetedhez
#   3. Töltsd fel a routerre az setup.rsc mellé
#
# A credentials.rsc fájl a .gitignore-ban van, így soha nem kerül a repo-ba.
# ============================================================================

# --- iDRAC kapcsolat --------------------------------------------------------
:global idracHost    "10.1.1.8"
:global idracUser    "your-idrac-user"
:global idracPass    "your-idrac-password"

# --- Konténer SSH hozzáférés ------------------------------------------------
:global sshRootPass  "your-container-ssh-password"

# --- Fan control beállítások ------------------------------------------------
:global tempQuiet    "70"
:global tempMax      "85"
:global speedQuiet   "0x02"
:global speedMedium  "0x08"
:global checkInterval "30"
